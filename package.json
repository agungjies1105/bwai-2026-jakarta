{
  "name": "luxebite-order-app",
  "version": "1.0.0",
  "description": "Premium gourmet food ordering web application",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./public/src/input.css -o ./public/dist/output.css --minify",
    "watch:css": "tailwindcss -i ./public/src/input.css -o ./public/dist/output.css --watch",
    "start": "node server.js",
    "dev": "npm run build:css && node server.js"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.15"
  }
}
